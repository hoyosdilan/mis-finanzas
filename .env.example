# Config web de tu proyecto Firebase (Consola → Configuración del proyecto →
# Tus apps → App web). Estos valores NO son secretos, pero cada instancia usa
# los suyos. Copia este archivo a .env y pobla los valores.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Clave pública Web Push (VAPID): Consola → Cloud Messaging →
# Certificados push web. Necesaria solo para notificaciones push.
VITE_FCM_VAPID_KEY=
