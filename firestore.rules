rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if the user is in the allowedEmails array
    function isUserAllowed() {
      return request.auth != null && 
             request.auth.token.email in get(/databases/$(database)/documents/finance_settings/users).data.allowedEmails;
    }

    // Rules for the 'finance_settings/users' whitelist document itself
    match /finance_settings/users {
      // Members can read the whitelist. Before it exists (bootstrap) any
      // logged-in user may read, only to discover it's missing; non-members
      // get permission-denied instead of reading the owner's email.
      allow read: if request.auth != null &&
                  (!exists(/databases/$(database)/documents/finance_settings/users) || isUserAllowed());
      // Creation only during bootstrap, and only by the owner
      allow create: if request.auth != null &&
                    !exists(/databases/$(database)/documents/finance_settings/users) &&
                    request.auth.token.email == 'hoyosdilan@gmail.com';
      // Allow modifications ONLY by people already in the whitelist
      allow update, delete: if isUserAllowed();
    }

    // Rules for all other documents in the database.
    // gmail_auth/ and processed_gmail_ids/ are excluded on purpose: they hold
    // backend-only data (the Gmail OAuth token and processed email IDs) and
    // must stay unreadable from the client. The Admin SDK used by the sync job
    // bypasses security rules, so the backend can still read/write them.
    match /{collectionId}/{document=**} {
      // Only authenticated users inside the whitelist can access financial data
      allow read, write: if isUserAllowed()
                         && collectionId != 'gmail_auth'
                         && collectionId != 'processed_gmail_ids';
    }
  }
}